---
// Footer component
import { Icon } from 'astro-icon/components';

const currentYear = new Date().getFullYear();

const socialLinks = [
  { name: "GitHub", url: "https://github.com/alpertoruun", icon: "ph:github-logo-bold" },
  { name: "LinkedIn", url: "https://www.linkedin.com/in/alper-torun/", icon: "ph:linkedin-logo-bold" },
  { name: "YouTube", url: "https://www.youtube.com/@alpertorunn", icon: "ph:youtube-logo-bold" },
  { name: "Email", url: "mailto:alpertorun4@hotmail.com", icon: "ph:envelope-simple-bold" },
];

const quickLinks = [
  { name: "Tech Stack", href: "#tech" },
  { name: "Certifications", href: "#certifications" },
  { name: "Experience", href: "#experience" },
  { name: "Projects", href: "#projects" },
];
---

<footer class="py-16 px-4 sm:px-6 lg:px-8 border-t border-ink-200">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">
      {/* Brand */}
      <div>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-ink-950 flex items-center justify-center">
            <span class="text-white font-display font-bold text-sm">AT</span>
          </div>
          <div>
            <div class="font-display font-bold text-ink-950">Alper Torun</div>
            <div class="text-sm text-ink-500">Platform Engineer</div>
          </div>
        </div>
        <p class="text-sm text-ink-600 leading-relaxed">
          Building scalable infrastructure and developer platforms.
          AWS Solutions Architect &amp; CKA certified.
        </p>
      </div>

      {/* Quick Links */}
      <div>
        <h4 class="font-semibold text-ink-900 mb-4">Quick Links</h4>
        <ul class="space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-ink-600 hover:text-accent transition-colors"
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h4 class="font-semibold text-ink-900 mb-4">Get in Touch</h4>
        <div class="space-y-3">
          <a
            href="mailto:alpertorun4@hotmail.com"
            class="flex items-center gap-2 text-sm text-ink-600 hover:text-accent transition-colors"
          >
            <Icon name="ph:envelope-simple-bold" class="w-4 h-4" />
            alpertorun4@hotmail.com
          </a>
          <p class="flex items-center gap-2 text-sm text-ink-600">
            <Icon name="ph:map-pin-bold" class="w-4 h-4" />
            Izmir, Turkey
          </p>
        </div>
      </div>
    </div>

    {/* Bottom */}
    <div class="pt-8 border-t border-ink-200 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-ink-500">
        © {currentYear} Alper Torun. Built with Astro &amp; Tailwind CSS.
      </p>

      {/* Social Links */}
      <div class="flex items-center gap-3">
        {socialLinks.map((social) => (
          <a
            href={social.url}
            target={social.url.startsWith('mailto') ? '_self' : '_blank'}
            rel={social.url.startsWith('mailto') ? '' : 'noopener noreferrer'}
            class="p-2 rounded-lg bg-ink-100 hover:bg-accent/10 border border-ink-200 hover:border-accent/30 transition-all group"
            aria-label={social.name}
          >
            <Icon name={social.icon} class="w-4 h-4 text-ink-600 group-hover:text-accent transition-colors" />
          </a>
        ))}
      </div>
    </div>
  </div>
</footer>
