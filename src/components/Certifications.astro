---
// Certifications Section - Highlight professional certifications with verified badge styling
import { Icon } from 'astro-icon/components';

const certifications = [
  {
    name: "Certified Kubernetes Administrator",
    shortName: "CKA",
    issuer: "The Linux Foundation",
    date: "October 2025",
    credlyUrl: "https://www.credly.com/badges/546d92e0-f4b8-46fd-91cd-4c01fded5f73/public_url",
    icon: "ph:cube-bold",
    color: "#326ce5",
    description: "A hands-on, timed exam covering Kubernetes cluster administration, troubleshooting, networking, and security. No multiple choice.",
  },
  {
    name: "AWS Solutions Architect",
    shortName: "SAA",
    issuer: "Amazon Web Services",
    date: "May 2024",
    credlyUrl: "https://www.credly.com/badges/16fd9c98-14f6-43e1-b8a8-886ca3132686/linked_in_profile",
    icon: "ph:cloud-bold",
    color: "#c9720a",
    description: "Covers designing distributed systems on AWS, cutting infrastructure costs, and building secure architectures.",
  }
];
---

<section id="certifications" class="py-20 px-4 sm:px-6 lg:px-8 bg-ink-100">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-14 max-w-2xl">
      <span class="inline-block text-xs font-mono uppercase tracking-[0.18em] text-success mb-3">
        Verified credentials
      </span>
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Professional certifications
      </h2>
      <p class="text-ink-600 leading-relaxed">
        Two exams I actually studied for and still use on the job.
      </p>
    </div>

    <!-- Certifications Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {certifications.map((cert, idx) => (
        <a
          href={cert.credlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group block opacity-0 animate-slide-up"
          style={`animation-delay: ${idx * 0.15}s`}
        >
          <div class="panel bg-white p-6 h-full relative" style={`border-top: 3px solid ${cert.color}`}>
            <!-- Verified Badge -->
            <div class="absolute top-4 right-4">
              <div class="flex items-center gap-1.5 px-3 py-1 rounded-full bg-success/10 border border-success/20">
                <Icon name="ph:seal-check-bold" class="w-4 h-4 text-success" />
                <span class="text-xs font-semibold text-success">Verified</span>
              </div>
            </div>

            <!-- Content -->
            <div class="flex items-start gap-4">
              <div
                class="flex-shrink-0 w-14 h-14 rounded-2xl flex items-center justify-center"
                style={`background-color: ${cert.color}1a;`}
              >
                <Icon name={cert.icon} class="w-7 h-7" style={`color: ${cert.color}`} />
              </div>

              <div class="flex-1 min-w-0">
                <span class="text-2xl font-display font-bold" style={`color: ${cert.color}`}>
                  {cert.shortName}
                </span>

                <h3 class="text-lg font-semibold text-ink-950 mt-1 mb-1 group-hover:text-accent transition-colors">
                  {cert.name}
                </h3>

                <div class="flex items-center gap-2 text-sm text-ink-500 mb-3">
                  <span>{cert.issuer}</span>
                  <span>&middot;</span>
                  <span>{cert.date}</span>
                </div>

                <p class="text-sm text-ink-600 leading-relaxed">
                  {cert.description}
                </p>
              </div>
            </div>

            <!-- View Certificate CTA -->
            <div class="mt-4 pt-4 border-t border-ink-200 flex items-center justify-between">
              <span class="text-sm text-ink-500">View on Credly</span>
              <Icon name="ph:arrow-up-right-bold" class="w-4 h-4 text-ink-500 group-hover:text-accent group-hover:translate-x-1 group-hover:-translate-y-0.5 transition-all" />
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
