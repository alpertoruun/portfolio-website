---

<section id="experience" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-14 max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Work experience
      </h2>
      <p class="text-ink-600 leading-relaxed">
        Building infrastructure and developer platforms at scale.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      {/* Timeline Line */}
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-ink-200 transform md:-translate-x-1/2 hidden md:block"></div>

      {experiences.map((exp, idx) => (
        <div
          class={`relative mb-12 last:mb-0 md:mb-16 opacity-0 animate-slide-up`}
          style={`animation-delay: ${idx * 0.15}s`}
        >
          <div class={`md:flex items-start gap-8 ${idx % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
            {/* Timeline Dot */}
            <div class="hidden md:flex absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-accent border-4 border-ink-50 z-10"></div>

            {/* Date Badge (Center) */}
            <div class={`hidden md:block absolute left-1/2 transform -translate-x-1/2 top-8 ${idx % 2 === 0 ? 'md:top-0 md:translate-y-0' : 'md:top-0'}`}>
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${exp.type === 'current' ? 'bg-success/10 text-success' : 'bg-ink-100 text-ink-600'}`}>
                {exp.period}
              </span>
            </div>

            {/* Content Card */}
            <div class={`md:w-[calc(50%-2rem)] ${idx % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
              <div class="panel bg-white p-6">
                {/* Header */}
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      {exp.type === 'current' && (
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
                        </span>
                      )}
                      <h3 class="text-xl font-display font-bold text-ink-950">{exp.company}</h3>
                    </div>
                    <p class="text-accent font-semibold">{exp.role}</p>
                    <p class="text-sm text-ink-500 mt-1">{exp.location}</p>
                    {exp.promotedTo && (
                      <span class="inline-flex items-center gap-1 mt-2 px-2 py-0.5 rounded-full bg-success/10 text-success text-xs font-semibold border border-success/20">
                        <Icon name="ph:trend-up-bold" class="w-3 h-3" />
                        Promoted to {exp.promotedTo}
                      </span>
                    )}
                  </div>
                </div>

                {/* Mobile Date */}
                <div class="md:hidden mb-4">
                  <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${exp.type === 'current' ? 'bg-success/10 text-success' : 'bg-ink-100 text-ink-600'}`}>
                    {exp.period}
                  </span>
                </div>

                {/* Highlights */}
                <div class="space-y-3 mb-4">
                  {exp.highlights.map((highlight) => (
                    <div class="flex items-start gap-3 p-3 rounded-xl bg-ink-50 hover:bg-ink-100 transition-colors">
                      <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-white border border-ink-200 flex items-center justify-center text-ink-700">
                        <Icon name={highlight.icon} class="w-4 h-4" />
                      </span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <h4 class="font-semibold text-ink-900 text-sm">{highlight.title}</h4>
                          {highlight.metric && (
                            <span class="px-2 py-0.5 rounded-full bg-accent/10 text-accent text-xs font-medium">
                              {highlight.metric}
                            </span>
                          )}
                        </div>
                        <p class="text-xs text-ink-600 leading-relaxed">{highlight.description}</p>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Technologies */}
                <div class="flex flex-wrap gap-1.5">
                  {exp.technologies.map((tech) => (
                    <span class="px-2 py-1 rounded-md bg-ink-100 text-ink-700 text-xs font-medium">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
