---
// Experience Section - Clean timeline with role highlights
import { Icon } from 'astro-icon/components';

const experiences = [
  {
    company: "Getir",
    role: "Platform & Infrastructure Engineer II",
    period: "January 2026 - Present",
    location: "Izmir, Turkey (Hybrid)",
    type: "current",
    highlights: [
      {
        title: "Karpenter Cost Optimization",
        description: "Retuned Karpenter cluster-wide: new NodePools, consolidation policies (WhenUnderutilized + WhenEmpty), and a reworked Spot/On-Demand split in production.",
        metric: "~30% cost cut",
        icon: "ph:coin-bold"
      },
      {
        title: "Blue-Green Node Migration",
        description: "Moved about 1000 nodes from the old NodePools to the new ones using a blue-green strategy, Bash automation, and a nightly cron job that drained nodes overnight. Nobody outside the team noticed it happened.",
        metric: "~1000 nodes",
        icon: "ph:arrows-left-right-bold"
      },
      {
        title: "Karpenter on EKS Fargate",
        description: "Moved the Karpenter controllers themselves onto EKS Fargate across 5 clusters, which retired about 50 always-on management nodes we no longer needed. Had to work out the IAM roles, Fargate profiles, and HA tolerations from scratch.",
        metric: "5 clusters",
        icon: "ph:cube-bold"
      },
      {
        title: "Observability Pipeline",
        description: "Built a Fargate-native logging pipeline for Karpenter and control-plane logs: CloudWatch to Kinesis Firehose to New Relic. Added dashboards and Slack alerts so on-call finds out before a user does.",
        metric: "Proactive alerting",
        icon: "ph:chart-line-bold"
      },
      {
        title: "Multi-Cluster Segregation",
        description: "Split Kubernetes clusters by business vertical, Payment and Marketplace, so a problem in one can't take down the other. Used ArgoCD's App of Apps pattern to manage deployments across all of them from one place.",
        metric: "Vertical isolation",
        icon: "ph:stack-bold"
      }
    ],
    technologies: ["Karpenter", "EKS Fargate", "ArgoCD", "New Relic", "Kinesis Firehose", "CloudWatch", "Bash", "Kubernetes"]
  },
  {
    company: "Getir",
    role: "Platform & Infrastructure Engineer I",
    period: "July 2025 - January 2026",
    location: "Izmir, Turkey (Hybrid)",
    type: "recent",
    promotedTo: "Engineer II",
    highlights: [
      {
        title: "Bitbucket to GitHub Migration",
        description: "Moved 4000+ repositories from Bitbucket to GitHub with Go and Bash scripts I wrote for the migration. Along the way, built reusable GitHub Actions workflows, switched to AWS OIDC instead of long-lived credentials, and rolled out CodeQL rulesets company-wide.",
        metric: "4000+ repos",
        icon: "ph:arrows-left-right-bold"
      },
      {
        title: "Internal Developer Platform",
        description: "Built 'Kitchen,' Getir's internal developer platform, on top of Backstage. Teams scaffold microservices, provision Vault and ECR, and set up ArgoCD and CI themselves, in one click, instead of filing a ticket and waiting.",
        metric: "400+ developers",
        icon: "ph:wrench-bold"
      },
      {
        title: "GitOps & Infrastructure",
        description: "Managed ArgoCD across multiple clusters, wrote the AWS CDK and Terraform modules behind them, and moved our Terraform workflows to Atlantis, so changes get approved through a pull request instead of someone running apply from their laptop.",
        metric: "Multi-cluster",
        icon: "ph:cube-bold"
      },
      {
        title: "Security & Cost Optimization",
        description: "Rolled out the Falcon-KAC admission controller through GitOps, then set up OpenCost with Kubeadapt and Athena pipelines so we could finally see where the cloud spend was going and how much Spot versus On-Demand was actually costing us.",
        metric: "Cost visibility",
        icon: "ph:coin-bold"
      }
    ],
    technologies: ["GitHub Actions", "ArgoCD", "Backstage", "AWS CDK", "Terraform", "Atlantis", "Go", "Kubernetes"]
  },
  {
    company: "P.I. Works",
    role: "Junior DevOps Engineer",
    period: "March 2025 - July 2025",
    location: "Istanbul, Turkey (Remote)",
    type: "recent",
    highlights: [
      {
        title: "DevOps AI System",
        description: "Built a code review system that used local LLMs through Ollama to check GitLab commits, merge requests, and failed pipelines automatically. Python Flask on the backend, RabbitMQ for the task queue.",
        metric: "AI-powered reviews",
        icon: "ph:robot-bold"
      },
      {
        title: "VS Code Extension Development",
        description: "Built a VS Code extension called 'DevOps Toolkit' with an interactive chat panel and automatic documentation generation, so people didn't have to leave their editor to use either.",
        metric: "IDE integration",
        icon: "ph:puzzle-piece-bold"
      },
      {
        title: "Infrastructure on Kubernetes",
        description: "Ran RabbitMQ, Elasticsearch, and Grafana on Kubernetes to keep an eye on throughput and latency for the AI analysis pipeline.",
        metric: "K8s deployment",
        icon: "ph:cube-bold"
      }
    ],
    technologies: ["Python Flask", "RabbitMQ", "Elasticsearch", "Grafana", "GitLab CI", "Kubernetes", "Ollama", "VS Code API"]
  },
  {
    company: "P.I. Works",
    role: "Part-Time Junior DevOps Engineer",
    period: "October 2023 - March 2025",
    location: "Istanbul, Turkey (Remote)",
    type: "past",
    highlights: [
      {
        title: "CI/CD Pipeline Engineering",
        description: "Kept the GitLab CI/CD pipelines for our microservices running and made them faster over time. Added cspell as a quality gate and scripted parts of the documentation nobody wanted to write by hand.",
        metric: "Pipeline automation",
        icon: "ph:arrows-clockwise-bold"
      },
      {
        title: "Linux System Administration",
        description: "Administered production and development Linux systems: kernel updates, performance tuning, security hardening.",
        metric: "System admin",
        icon: "ph:terminal-window-bold"
      },
      {
        title: "Monitoring & Observability",
        description: "Set up monitoring with Prometheus, Grafana, and the ELK stack, built custom dashboards, and wrote log rotation policies for Kubernetes so logs stopped filling up the disks.",
        metric: "Full observability",
        icon: "ph:chart-line-bold"
      },
      {
        title: "RAG-Based DevOps Agent",
        description: "Built a retrieval-augmented generation agent with vector embeddings and semantic search, so the team could find how a past issue was solved instead of solving it again from scratch.",
        metric: "Semantic search",
        icon: "ph:brain-bold"
      },
      {
        title: "Database & Dependency Management",
        description: "Set up automated dependency audits for our PostgreSQL setups, tracking versions and licenses, wired directly into the CI pipelines.",
        metric: "Package auditing",
        icon: "ph:package-bold"
      }
    ],
    technologies: ["GitLab CI", "Prometheus", "Grafana", "ELK Stack", "Python", "Bash", "PostgreSQL", "Linux", "cspell"]
  },
  {
    company: "P.I. Works",
    role: "DevOps Intern",
    period: "July 2023 - October 2023",
    location: "Istanbul, Turkey (Remote)",
    type: "past",
    highlights: [
      {
        title: "CI/CD Improvements",
        description: "Helped improve the GitLab CI/CD pipelines and added Microsoft Teams notifications for pipeline status, so people stopped refreshing the pipeline page every five minutes.",
        metric: "Pipeline notifications",
        icon: "ph:bell-bold"
      },
      {
        title: "Automation Scripts",
        description: "Automated dependency audits using Bash scripts. This was my first real hands-on work with DevOps workflows and Linux systems.",
        metric: "Bash scripting",
        icon: "ph:terminal-bold"
      }
    ],
    technologies: ["GitLab CI", "Bash", "Teams API", "Linux"]
  }
];
---

<section id="experience" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-14 max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Work experience
      </h2>
      <p class="text-ink-600 leading-relaxed">
        What I've worked on at Getir and P.I. Works since 2023.
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      {/* Timeline Line */}
      <div class="absolute left-0 md:left-1/2 top-0 bottom-0 w-px bg-ink-200 transform md:-translate-x-1/2 hidden md:block"></div>

      {experiences.map((exp, idx) => (
        <div
          class={`relative mb-12 last:mb-0 md:mb-16 opacity-0 animate-slide-up`}
          style={`animation-delay: ${idx * 0.15}s`}
        >
          <div class={`md:flex items-start gap-8 ${idx % 2 === 0 ? 'md:flex-row-reverse' : ''}`}>
            {/* Timeline Dot */}
            <div class="hidden md:flex absolute left-1/2 transform -translate-x-1/2 w-4 h-4 rounded-full bg-accent border-4 border-ink-50 z-10"></div>

            {/* Date Badge (Center) */}
            <div class={`hidden md:block absolute left-1/2 transform -translate-x-1/2 top-8 ${idx % 2 === 0 ? 'md:top-0 md:translate-y-0' : 'md:top-0'}`}>
              <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${exp.type === 'current' ? 'bg-success/10 text-success' : 'bg-ink-100 text-ink-600'}`}>
                {exp.period}
              </span>
            </div>

            {/* Content Card */}
            <div class={`md:w-[calc(50%-2rem)] ${idx % 2 === 0 ? 'md:mr-auto md:pr-8' : 'md:ml-auto md:pl-8'}`}>
              <div class="panel bg-white p-6">
                {/* Header */}
                <div class="flex items-start justify-between mb-4">
                  <div>
                    <div class="flex items-center gap-2 mb-1">
                      {exp.type === 'current' && (
                        <span class="relative flex h-2 w-2">
                          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                          <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
                        </span>
                      )}
                      <h3 class="text-xl font-display font-bold text-ink-950">{exp.company}</h3>
                    </div>
                    <p class="text-accent font-semibold">{exp.role}</p>
                    <p class="text-sm text-ink-500 mt-1">{exp.location}</p>
                    {exp.promotedTo && (
                      <span class="inline-flex items-center gap-1 mt-2 px-2 py-0.5 rounded-full bg-success/10 text-success text-xs font-semibold border border-success/20">
                        <Icon name="ph:trend-up-bold" class="w-3 h-3" />
                        Promoted to {exp.promotedTo}
                      </span>
                    )}
                  </div>
                </div>

                {/* Mobile Date */}
                <div class="md:hidden mb-4">
                  <span class={`inline-block px-3 py-1 rounded-full text-xs font-semibold ${exp.type === 'current' ? 'bg-success/10 text-success' : 'bg-ink-100 text-ink-600'}`}>
                    {exp.period}
                  </span>
                </div>

                {/* Highlights */}
                <div class="space-y-3 mb-4">
                  {exp.highlights.map((highlight) => (
                    <div class="flex items-start gap-3 p-3 rounded-xl bg-ink-50 hover:bg-ink-100 transition-colors">
                      <span class="flex-shrink-0 w-8 h-8 rounded-lg bg-white border border-ink-200 flex items-center justify-center text-ink-700">
                        <Icon name={highlight.icon} class="w-4 h-4" />
                      </span>
                      <div class="flex-1 min-w-0">
                        <div class="flex items-center gap-2 mb-1">
                          <h4 class="font-semibold text-ink-900 text-sm">{highlight.title}</h4>
                          {highlight.metric && (
                            <span class="px-2 py-0.5 rounded-full bg-accent/10 text-accent text-xs font-medium">
                              {highlight.metric}
                            </span>
                          )}
                        </div>
                        <p class="text-xs text-ink-600 leading-relaxed">{highlight.description}</p>
                      </div>
                    </div>
                  ))}
                </div>

                {/* Technologies */}
                <div class="flex flex-wrap gap-1.5">
                  {exp.technologies.map((tech) => (
                    <span class="px-2 py-1 rounded-md bg-ink-100 text-ink-700 text-xs font-medium">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
