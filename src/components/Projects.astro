---
// Projects Section - Showcase key projects with cards
import { Icon } from 'astro-icon/components';

const featured = {
  title: "Scalable Voting System",
  subtitle: "Cloud-Native AWS Application",
  description: "Engineered a voting system featuring biometric authentication with face recognition. Implemented liveness detection using OpenCV/MediaPipe and designed scalable infrastructure on AWS ECS with AutoScaling policies.",
  icon: "ph:check-square-bold",
  technologies: ["AWS ECS", "Python Flask", "OpenCV", "PostgreSQL", "Docker", "CloudWatch"],
  features: [
    "Face recognition with liveness detection",
    "AutoScaling based on CloudWatch metrics",
    "JWT authentication with secure backend",
    "Nginx reverse proxy configuration"
  ],
  githubUrl: "https://github.com/alpertoruun/VotingAppwithDockerandAWS",
  period: "2024 - 2025",
};

const projects = [
  {
    title: "DevOps AI System",
    subtitle: "LLM-Powered Code Review",
    description: "Automated code review system analyzing GitLab commits, Merge Requests, and failed pipelines using LLMs, with a custom VS Code extension for IDE integration.",
    icon: "ph:robot-bold",
    technologies: ["Python Flask", "RabbitMQ", "Ollama", "Elasticsearch"],
    status: "professional"
  },
  {
    title: "Internal Developer Platform",
    subtitle: "Backstage-based IDP",
    description: "Built Getir's central IDP 'Kitchen' enabling self-service scaffolding, Vault/ECR provisioning, and one-click ArgoCD enablement.",
    icon: "ph:cooking-pot-bold",
    technologies: ["Backstage.io", "TypeScript", "Vault", "ArgoCD"],
    status: "professional"
  },
  {
    title: "RAG DevOps Agent",
    subtitle: "AI Knowledge Base",
    description: "Retrieval-Augmented Generation agent using vector embeddings and semantic search to streamline internal issue resolution.",
    icon: "ph:brain-bold",
    technologies: ["Python", "Vector DB", "LLMs"],
    status: "professional"
  }
];
---

<section id="projects" class="py-20 px-4 sm:px-6 lg:px-8 bg-ink-100">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-14 max-w-2xl">
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Featured projects
      </h2>
      <p class="text-ink-600 leading-relaxed">
        Personal and professional work showcasing platform engineering depth.
      </p>
    </div>

    <!-- Featured project: full-width -->
    <div class="panel bg-white p-6 sm:p-8 mb-6 opacity-0 animate-slide-up">
      <div class="grid grid-cols-1 md:grid-cols-[auto_1fr] gap-6">
        <div class="w-16 h-16 rounded-2xl bg-ink-950 flex items-center justify-center text-white shrink-0">
          <Icon name={featured.icon} class="w-8 h-8" />
        </div>
        <div>
          <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
            <div>
              <h3 class="text-xl font-display font-bold text-ink-950">{featured.title}</h3>
              <p class="text-sm text-accent font-medium">{featured.subtitle}</p>
            </div>
            <a
              href={featured.githubUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-ink-100 hover:bg-ink-200 border border-ink-200 text-sm font-medium text-ink-800 transition-colors"
            >
              <Icon name="ph:github-logo-bold" class="w-4 h-4" />
              Source
            </a>
          </div>
          <p class="text-ink-600 leading-relaxed mb-4 max-w-[65ch]">{featured.description}</p>
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5 mb-4">
            {featured.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-ink-700">
                <Icon name="ph:check-bold" class="w-4 h-4 text-success flex-shrink-0 mt-0.5" />
                <span>{feature}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-wrap gap-1.5 pt-4 border-t border-ink-200">
            {featured.technologies.map((tech) => (
              <span class="px-2 py-1 rounded-md bg-ink-100 text-ink-700 text-xs font-medium">{tech}</span>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- Remaining projects: 3-col grid (distinct rhythm from the featured row above) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {projects.map((project, idx) => (
        <div
          class="panel bg-white p-6 flex flex-col h-full opacity-0 animate-scale-in"
          style={`animation-delay: ${idx * 0.1}s`}
        >
          <div class="w-12 h-12 rounded-xl bg-ink-100 flex items-center justify-center text-ink-800 mb-4">
            <Icon name={project.icon} class="w-6 h-6" />
          </div>
          <span class="text-xs font-medium text-accent mb-1">Professional</span>
          <h3 class="text-base font-bold text-ink-950 mb-1">{project.title}</h3>
          <p class="text-xs text-ink-500 mb-3">{project.subtitle}</p>
          <p class="text-sm text-ink-600 leading-relaxed mb-4 flex-1">{project.description}</p>
          <div class="flex flex-wrap gap-1.5 pt-4 border-t border-ink-200">
            {project.technologies.map((tech) => (
              <span class="px-2 py-1 rounded-md bg-ink-100 text-ink-700 text-xs font-medium">{tech}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    {/* GitHub CTA */}
    <div class="mt-12 text-center">
      <a
        href="https://github.com/alpertoruun"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-transparent hover:bg-ink-200 border border-ink-300 text-ink-900 font-semibold transition-all active:scale-[0.98]"
      >
        <Icon name="ph:github-logo-bold" class="w-5 h-5" />
        View all projects on GitHub
      </a>
    </div>
  </div>
</section>
