---
// YouTube Channel Highlights Section
// You can add your video IDs here to feature them
import { Icon } from 'astro-icon/components';

const featuredVideos = [
  {
    id: "Cm3XzmFLfXw",
    title: "DevOps = Otomasyon mu? Her Şeyi Otomatize Etmeli miyiz?",
  },
  {
    id: "FcoE_TCuA4k",
    title: "Sertifika Neyi Sağlar? AWS Solutions Architect Sertifikası ve Önemli AWS Servisleri",
  },
  {
    id: "8unhIU7uj3A",
    title: "Junior Devops Engineer Olur Mu?", 
  },
];

const channelStats = {
  channelUrl: "https://www.youtube.com/@alpertorunn",
  channelName: "@alpertorunn",
};
---

<section id="youtube" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="mb-14 max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Video content
      </h2>
      <p class="text-ink-600 leading-relaxed">
        DevOps and platform engineering videos, mostly in Turkish.
      </p>
    </div>

    <!-- Channel Card -->
    <div class="max-w-4xl mx-auto mb-12">
      <a
        href={channelStats.channelUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="group block"
      >
        <div class="panel bg-white p-6 sm:p-8 flex flex-col sm:flex-row items-center gap-6 hover:border-red-500/30">
          <!-- Channel Icon (real brand red — intentional, not decorative) -->
          <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl bg-red-500 flex items-center justify-center shrink-0">
            <Icon name="ph:youtube-logo-bold" class="w-10 h-10 sm:w-12 sm:h-12 text-white" />
          </div>

          <!-- Channel Info -->
          <div class="flex-1 text-center sm:text-left">
            <h3 class="text-2xl font-display font-bold text-ink-950 group-hover:text-red-500 transition-colors">
              Alper Torun
            </h3>
            <p class="text-ink-500 mb-3">{channelStats.channelName}</p>
            <p class="text-ink-600">
              DevOps tutorials and Kubernetes deep dives, recorded in Turkish
            </p>
          </div>

          <!-- Subscribe Button -->
          <div class="flex-shrink-0">
            <div class="inline-flex items-center gap-2 px-6 py-3 bg-red-500 group-hover:bg-red-600 text-white font-semibold rounded-xl transition-all">
              <Icon name="ph:play-fill" class="w-5 h-5" />
              Subscribe
            </div>
          </div>
        </div>
      </a>
    </div>

    <!-- Featured Videos Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featuredVideos.map((video, idx) => (
        <div
          class="panel bg-white overflow-hidden opacity-0 animate-scale-in"
          style={`animation-delay: ${idx * 0.1}s`}
        >
          <!-- Video Embed -->
          <div class="aspect-video bg-ink-100 relative">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}`}
              title={video.title}
              class="w-full h-full"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

          <!-- Video Info -->
          <div class="p-4">
            <h3 class="font-semibold text-ink-900 line-clamp-2">
              {video.title}
            </h3>
          </div>
        </div>
      ))}
    </div>

    <!-- View All CTA -->
    <div class="mt-12 text-center">
      <a
        href={channelStats.channelUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-transparent hover:bg-red-500/10 border border-ink-300 hover:border-red-500/30 text-ink-900 hover:text-red-500 font-semibold transition-all active:scale-[0.98]"
      >
        <Icon name="ph:youtube-logo-bold" class="w-5 h-5" />
        View all videos
      </a>
    </div>
  </div>
</section>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
