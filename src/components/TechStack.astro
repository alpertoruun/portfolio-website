---
// Tech Stack — bento grid with real brand colors as small identifiers, not full-fill pills.
import { Icon } from 'astro-icon/components';

const techCategories = [
  {
    title: "Cloud & Infrastructure",
    icon: "ph:cloud-bold",
    span: "md:col-span-2 lg:col-span-2",
    items: [
      { name: "AWS", color: "#c9720a" },
      { name: "EKS", color: "#c9720a" },
      { name: "Fargate", color: "#c9720a" },
      { name: "Lambda", color: "#c9720a" },
      { name: "CloudFront", color: "#c9720a" },
      { name: "S3", color: "#c9720a" },
      { name: "RDS", color: "#c9720a" },
    ]
  },
  {
    title: "Kubernetes & GitOps",
    icon: "ph:cube-bold",
    span: "",
    items: [
      { name: "Kubernetes", color: "#326ce5" },
      { name: "Docker", color: "#2496ed" },
      { name: "ArgoCD", color: "#d15a2e" },
      { name: "Helm", color: "#326ce5" },
      { name: "Karpenter", color: "#326ce5" },
    ]
  },
  {
    title: "Infrastructure as Code",
    icon: "ph:stack-bold",
    span: "",
    items: [
      { name: "Terraform", color: "#7b42bc" },
      { name: "AWS CDK", color: "#c9720a" },
      { name: "Atlantis", color: "#7b42bc" },
    ]
  },
  {
    title: "CI/CD & Automation",
    icon: "ph:arrows-clockwise-bold",
    span: "",
    items: [
      { name: "GitHub Actions", color: "#238636" },
      { name: "GitLab CI", color: "#d15a2e" },
      { name: "Bash", color: "#15803d" },
    ]
  },
  {
    title: "Platform Engineering",
    icon: "ph:toolbox-bold",
    span: "",
    items: [
      { name: "Backstage.io", color: "#0d9488" },
      { name: "HashiCorp Vault", color: "#9f123c" },
      { name: "OpenCost", color: "#9f123c" },
    ]
  },
  {
    title: "Languages",
    icon: "ph:code-bold",
    span: "",
    items: [
      { name: "Go", color: "#2496ed" },
      { name: "Python", color: "#c9720a" },
      { name: "TypeScript", color: "#326ce5" },
      { name: "Bash", color: "#15803d" },
    ]
  },
  {
    title: "Observability",
    icon: "ph:chart-line-bold",
    span: "md:col-span-2 lg:col-span-1",
    items: [
      { name: "Prometheus", color: "#d15a2e" },
      { name: "Grafana", color: "#c9720a" },
      { name: "New Relic", color: "#9f123c" },
      { name: "ELK Stack", color: "#326ce5" },
      { name: "CloudWatch", color: "#c9720a" },
    ]
  }
];
---

<section id="tech" class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header (left-aligned — breaks the centered-hero-then-centered-everything rhythm) -->
    <div class="mb-14 max-w-2xl">
      <h2 class="text-3xl sm:text-4xl font-display font-bold text-ink-950 mb-3">
        Tech stack &amp; expertise
      </h2>
      <p class="text-ink-600 leading-relaxed">
        The tools I reach for daily to keep production clusters running.
      </p>
    </div>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {techCategories.map((category, idx) => (
        <div
          class={`panel p-6 opacity-0 animate-scale-in ${category.span}`}
          style={`animation-delay: ${idx * 0.1}s`}
        >
          <div class="flex items-center gap-3 mb-4">
            <span class="flex items-center justify-center w-9 h-9 rounded-lg bg-ink-100 text-ink-800">
              <Icon name={category.icon} class="w-5 h-5" />
            </span>
            <h3 class="text-base font-semibold text-ink-900">{category.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {category.items.map((item) => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-ink-50 text-ink-700 border border-ink-200">
                <span class="w-1.5 h-1.5 rounded-full" style={`background-color: ${item.color}`}></span>
                {item.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Highlight strip -->
    <div class="mt-8 panel px-6 py-5 flex flex-col sm:flex-row items-center justify-center gap-3 text-center">
      <span class="font-display font-semibold text-ink-900">Kubernetes, ArgoCD, and Backstage.</span>
      <span class="text-ink-500">The stack behind almost everything I ship.</span>
    </div>
  </div>
</section>
