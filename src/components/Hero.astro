---
// Hero Section — asymmetric split, single accent, no gradient blobs.
import { Icon } from 'astro-icon/components';
---

<section class="min-h-screen flex items-center px-4 sm:px-6 lg:px-8 pt-24 pb-20">
  <div class="max-w-6xl mx-auto w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Left: Text Content (wider column, left-aligned — no centered-hero cliché) -->
      <div class="lg:col-span-7 order-2 lg:order-1 text-center lg:text-left">
        <p class="text-sm font-mono uppercase tracking-[0.18em] text-ink-500 opacity-0 animate-slide-up stagger-1">
          Platform Engineer &amp; Cloud Architect
        </p>

        <h1 class="mt-4 text-4xl sm:text-5xl lg:text-6xl font-display font-bold tracking-tight leading-[1.05] text-ink-950 opacity-0 animate-slide-up stagger-2">
          From code to production, <em class="not-italic text-accent">automated</em>.
        </h1>

        <p class="mt-6 text-lg text-ink-600 leading-relaxed opacity-0 animate-slide-up stagger-3 max-w-[52ch] mx-auto lg:mx-0">
          I build and run the platforms other engineers ship on top of: Kubernetes, GitOps, AWS, and the internal developer tooling at Getir.
        </p>

        <!-- Key Stats -->
        <div class="flex flex-wrap justify-center lg:justify-start gap-8 mt-9 opacity-0 animate-slide-up stagger-3">
          <div class="text-center lg:text-left">
            <div class="text-2xl font-display font-bold text-ink-950">CKA</div>
            <div class="text-sm text-ink-500 mt-1">Certified Kubernetes Administrator</div>
          </div>
          <div class="w-px h-11 bg-ink-200"></div>
          <div class="text-center lg:text-left">
            <div class="text-2xl font-display font-bold text-ink-950">AWS SAA</div>
            <div class="text-sm text-ink-500 mt-1">Solutions Architect</div>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row justify-center lg:justify-start gap-3 mt-9 opacity-0 animate-slide-up stagger-4">
          <a
            href="#experience"
            class="group inline-flex items-center justify-center gap-2 px-6 py-3 bg-ink-950 hover:bg-ink-900 text-white font-semibold rounded-xl transition-all duration-300 active:scale-[0.98]"
          >
            View my work
            <Icon name="ph:arrow-right-bold" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
          </a>
          <a
            href="https://github.com/alpertoruun"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-2 px-6 py-3 bg-transparent hover:bg-ink-100 text-ink-900 font-semibold rounded-xl border border-ink-300 transition-all duration-300 active:scale-[0.98]"
          >
            <Icon name="ph:github-logo-bold" class="w-5 h-5" />
            GitHub
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex justify-center lg:justify-start gap-3 mt-8 opacity-0 animate-fade-in stagger-5">
          <a
            href="https://www.linkedin.com/in/alper-torun/"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 rounded-xl bg-ink-100 hover:bg-[#0077b5]/10 border border-ink-200 hover:border-[#0077b5]/40 transition-all duration-300 group"
            aria-label="LinkedIn"
          >
            <Icon name="ph:linkedin-logo-bold" class="w-5 h-5 text-ink-600 group-hover:text-[#0077b5] transition-colors" />
          </a>
          <a
            href="https://www.youtube.com/@alpertorunn"
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 rounded-xl bg-ink-100 hover:bg-red-500/10 border border-ink-200 hover:border-red-500/40 transition-all duration-300 group"
            aria-label="YouTube"
          >
            <Icon name="ph:youtube-logo-bold" class="w-5 h-5 text-ink-600 group-hover:text-red-500 transition-colors" />
          </a>
          <a
            href="mailto:alpertorun4@hotmail.com"
            class="p-3 rounded-xl bg-ink-100 hover:bg-accent/10 border border-ink-200 hover:border-accent/40 transition-all duration-300 group"
            aria-label="Email"
          >
            <Icon name="ph:envelope-simple-bold" class="w-5 h-5 text-ink-600 group-hover:text-accent transition-colors" />
          </a>
        </div>
      </div>

      <!-- Right: Profile Photo — offset frame instead of a blurred glow -->
      <div class="lg:col-span-5 order-1 lg:order-2 flex justify-center opacity-0 animate-scale-in stagger-2">
        <div class="relative">
          <div class="absolute -bottom-4 -right-4 w-full h-full rounded-3xl bg-ink-950"></div>
          <div class="relative w-60 h-80 sm:w-72 sm:h-[26rem] rounded-3xl overflow-hidden border border-ink-200 shadow-[0_1px_2px_rgba(26,24,21,0.04),0_30px_60px_-24px_rgba(26,24,21,0.28)]">
            <img
              src="/profile.jpg"
              alt="Portrait of Alper Torun"
              class="w-full h-full object-cover object-top"
              loading="eager"
            />
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-ink-950/70 via-ink-950/10 to-transparent">
              <div class="font-display font-bold text-white">Alper Torun</div>
              <div class="text-sm text-white/80">Platform Engineer</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="flex justify-center mt-16 opacity-0 animate-fade-in stagger-6 hidden lg:flex">
      <div class="flex flex-col items-center gap-2 text-ink-400">
        <span class="text-xs font-mono uppercase tracking-widest">Scroll</span>
        <div class="w-5 h-8 rounded-full border-2 border-ink-300 flex justify-center pt-2">
          <div class="w-1 h-2 bg-ink-400 rounded-full animate-bounce"></div>
        </div>
      </div>
    </div>
  </div>
</section>
